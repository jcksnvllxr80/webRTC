      "roundness": null,
      "seed": 1030,
      "version": 1,
      "versionNonce": 2030,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1,
      "link": null,
      "locked": false,
      "text": "Connection Flow: Authenticate (HTTPS) > Join Room (Socket.IO) > Exchange SDP offers/answers via server > Exchange ICE candidates\n> Establish direct P2P connection (or TURN relay if behind symmetric NAT) > Media streams flow peer-to-peer\nClients connect via any modern browser (Chrome, Firefox, Edge, Safari) or the Electron desktop app (Windows / macOS / Linux)",
      "fontSize": 14,
      "fontFamily": 1,
      "textAlign": "center",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Connection Flow: Authenticate (HTTPS) > Join Room (Socket.IO) > Exchange SDP offers/answers via server > Exchange ICE candidates\n> Establish direct P2P connection (or TURN relay if behind symmetric NAT) > Media streams flow peer-to-peer\nClients connect via any modern browser (Chrome, Firefox, Edge, Safari) or the Electron desktop app (Windows / macOS / Linux)",
      "autoResize": true,
      "lineHeight": 1.25
    },

{
  "name": "webrtc",
  "version": "0.8.4",
  "description": "A little WebRTC sample project with hosted https server\n",
  "main": "src/desktop/main.js",
  "scripts": {
    "start": "node src/server/index.js",
    "server": "node src/server/index.js",
    "electron": "electron .",
    "build": "electron-builder",
    "build:editor": "esbuild src/web/editor-src/index.js --bundle --format=esm --target=es2020 --outfile=src/web/public/js/chat-editor.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@tiptap/extension-code-block-lowlight": "^3.20.5",
    "@tiptap/extension-highlight": "^3.20.5",
    "@tiptap/extension-image": "^3.20.5",
    "@tiptap/extension-link": "^3.20.5",
    "@tiptap/extension-placeholder": "^3.20.5",
    "@tiptap/starter-kit": "^3.20.5",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.8.0",
    "dompurify": "^3.3.3",
    "emoji-picker-element": "^1.29.1",
    "express": "^5.1.0",
    "express-session": "^1.18.1",
    "lowlight": "^3.3.0",
    "socket.io": "^4.8.1"
  },
  "build": {
    "appId": "com.yourapp.webrtc",
    "productName": "WebRTC Desktop",
    "npmRebuild": false,
    "files": [
      "src/desktop/**/*"
    ],
    "mac": {
      "category": "public.app-category.video"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "esbuild": "^0.27.4"
  }
}
